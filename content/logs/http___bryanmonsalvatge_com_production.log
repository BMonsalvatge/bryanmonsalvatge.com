{"name":"Log","hostname":"localhost","pid":3440,"level":30,"req":{"meta":{"requestId":"eee56dc0-ff96-11e7-8e5d-e1b8077bf2ad","userId":"1"},"url":"/posts/5a661466f98e080d70b4d43e/?include=tags","method":"PUT","originalUrl":"/ghost/api/v0.1/posts/5a661466f98e080d70b4d43e/?include=tags","params":{"id":"5a661466f98e080d70b4d43e"},"headers":{"x-forwarded-for":"67.8.27.65","x-forwarded-proto":"https","x-real-ip":"67.8.27.65","host":"bryanmonsalvatge.com","connection":"close","content-length":"4014","user-agent":"Mozilla/5.0 (Macintosh; Intel Mac OS X 10.12; rv:57.0) Gecko/20100101 Firefox/57.0","accept":"application/json, text/javascript, */*; q=0.01","accept-language":"en-US,en;q=0.5","accept-encoding":"gzip, deflate, br","referer":"https://bryanmonsalvatge.com/ghost/","content-type":"application/json; charset=utf-8","x-ghost-version":"1.19","app-pragma":"no-cache","x-requested-with":"XMLHttpRequest"},"body":{"posts":{"0":{"id":"5a661466f98e080d70b4d43e","created_at":"2018-01-22T16:42:14.000Z","featured":false,"codeinjection_foot":"","codeinjection_head":"","mobiledoc":"{\"version\":\"0.3.1\",\"markups\":[],\"atoms\":[],\"cards\":[[\"card-markdown\",{\"cardName\":\"card-markdown\",\"markdown\":\"My name is Bryan Monsalvatge.  I was born and raised in Coral Springs, Florida.  From a young age I have always been interested in what makes computers tick.  Ever since I added my first graphics card to an HP computer and realized shortly after I needed to upgrade my power supply as well, I was hooked. After going to Broward College for about 1 year I moved up to Orlando to attend Valencia College.  After about semester at Valencia I found out I needed to have surgery and had to sit out a semester.  During that time I came across great opportunity at SingleHop as a System Administrator.  There I have a chance to really harness my passion for technology in a very practical way and have learned a plethura of knowledge surrounding data center operations.\\n\\nMy main passion surrounding computers has always been creation.  So naturally software development has been a field that has always interested me.  Even during high school I remember learning C++ and SDL so I could actually make a game engine, before easily available solutions like Unity and Unreal came into the market.\\n\\nToday I find myself tinkering with the latest techologies and how they can be used together to create powerful tools, systems, and applications.  I hope to add more to this blog/portfolio as I continue to learn and as I find time to do so.\\n\\nIf you have any feedback for me about a blogpost or project I have worked on, please don't hesistate to reach out!  \"}]],\"sections\":[[10,0]]}","page":true,"plaintext":"My name is Bryan Monsalvatge. I was born and raised in Coral Springs, Florida.\nFrom a young age I have always been interested in what makes computers tick.\nEver since I added my first graphics card to an HP computer and realized shortly\nafter I needed to upgrade my power supply as well, I was hooked. After going to\nBroward College for about 1 year I moved up to Orlando to attend Valencia\nCollege. After about semester at Valencia I found out I needed to have surgery\nand had to sit out a semester. During that time I came across great opportunity\nat SingleHop as a System Administrator. There I have a chance to really harness\nmy passion for technology in a very practical way and have learned a plethura of\nknowledge surrounding data center operations.\n\nMy main passion surrounding computers has always been creation. So naturally\nsoftware development has been a field that has always interested me. Even during\nhigh school I remember learning C++ and SDL so I could actually make a game\nengine, before easily available solutions like Unity and Unreal came into the\nmarket.\n\nToday I find myself tinkering with the latest techologies and how they can be\nused together to create powerful tools, systems, and applications. I hope to add\nmore to this blog/portfolio as I continue to learn and as I find time to do so.\n\nIf you have any feedback for me about a blogpost or project I have worked on,\nplease don't hesistate to reach out!","published_at":"2018-01-22T16:54:19.000Z","slug":"about","status":"published","title":"(Untitled)","updated_at":"2018-01-22T17:08:44.000Z","updated_by":"1","tags":{"0":{"id":"5a661466f98e080d70b4d43f","name":"About","slug":"about","description":null,"parent":null,"meta_title":null,"meta_description":null,"feature_image":null,"visibility":"public","created_at":"2018-01-22T16:42:14.000Z","updated_at":"2018-01-22T17:08:44.000Z","created_by":"1","updated_by":"1"}},"author_id":"1"}}},"query":{"include":"tags"}},"res":{"_headers":{"x-powered-by":"Express","cache-control":"no-cache, private, no-store, must-revalidate, max-stale=0, post-check=0, pre-check=0","x-cache-invalidate":"/*","content-type":"application/json; charset=utf-8","etag":"W/\"b37-mE7RblWOvnE+3qTQwfCnLNpC6tc\"","vary":"Accept-Encoding","content-encoding":"gzip"},"statusCode":200,"responseTime":"159ms"},"msg":"","time":"2018-01-22T17:08:57.794Z","v":0}

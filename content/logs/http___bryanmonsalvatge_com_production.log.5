{"name":"Log","hostname":"localhost","pid":3440,"level":30,"req":{"meta":{"requestId":"769cebb0-fd3c-11e7-8e5d-e1b8077bf2ad","userId":null},"url":"/2018/01/Screen-Shot-2017-10-02-at-10.19.06-PM.jpg","method":"GET","originalUrl":"/content/images/2018/01/Screen-Shot-2017-10-02-at-10.19.06-PM.jpg","params":{},"headers":{"x-forwarded-for":"173.230.133.130","x-forwarded-proto":"https","x-real-ip":"173.230.133.130","host":"bryanmonsalvatge.com","connection":"close","user-agent":"Mozilla/5.0","accept-encoding":"gzip,deflate"},"body":{},"query":{}},"res":{"_headers":{"x-powered-by":"Express","accept-ranges":"bytes","cache-control":"public, max-age=31536000","last-modified":"Wed, 03 Jan 2018 22:15:57 GMT","etag":"W/\"789e7-160be1864b1\"","content-type":"image/jpeg","content-length":494055},"statusCode":200,"responseTime":"8ms"},"msg":"","time":"2018-01-19T17:16:18.806Z","v":0}

{"name":"Log","hostname":"localhost","pid":3440,"level":30,"req":{"meta":{"requestId":"e3498b60-ff94-11e7-8e5d-e1b8077bf2ad","userId":"1"},"url":"/posts/5a661466f98e080d70b4d43e/?include=tags","method":"PUT","originalUrl":"/ghost/api/v0.1/posts/5a661466f98e080d70b4d43e/?include=tags","params":{"id":"5a661466f98e080d70b4d43e"},"headers":{"x-forwarded-for":"67.8.27.65","x-forwarded-proto":"https","x-real-ip":"67.8.27.65","host":"bryanmonsalvatge.com","connection":"close","content-length":"2531","user-agent":"Mozilla/5.0 (Macintosh; Intel Mac OS X 10.12; rv:57.0) Gecko/20100101 Firefox/57.0","accept":"application/json, text/javascript, */*; q=0.01","accept-language":"en-US,en;q=0.5","accept-encoding":"gzip, deflate, br","referer":"https://bryanmonsalvatge.com/ghost/","content-type":"application/json; charset=utf-8","x-ghost-version":"1.19","app-pragma":"no-cache","x-requested-with":"XMLHttpRequest"},"body":{"posts":{"0":{"id":"5a661466f98e080d70b4d43e","created_at":"2018-01-22T16:42:14.000Z","featured":false,"codeinjection_foot":"","codeinjection_head":"","mobiledoc":"{\"version\":\"0.3.1\",\"markups\":[],\"atoms\":[],\"cards\":[[\"card-markdown\",{\"cardName\":\"card-markdown\",\"markdown\":\"My name is Bryan Monsalvatge.  I was born and raised in Coral Springs, Florida.  From a young age I have always been interested in what makes computers tick.  Ever since I added my first graphics card to an HP computer and realized shortly after I needed to upgrade my power supply as well, I was hooked. After going to Broward College for about 1 year I moved up to Orlando to attend Valencia College.  After about semester at Valencia I found out I needed to have surgery and had to sit out a semester.  During that time I came across great opportunity at SingleHop as a System Administrator.  There I have a chance to really harness my passion for technology in a very practical way and have learned a plethura of knowledge surrounding data center operations.\\n\\nMy main passion surrou